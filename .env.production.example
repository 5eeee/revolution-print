# ============================================
# Revolution Print — Production Environment
# ============================================
# Скопируйте этот файл в .env.production
#   cp .env.production.example .env.production
# и заполните реальными значениями.
# ============================================

# --- Домен ---
DOMAIN=print.example.com

# --- PostgreSQL ---
DB_USER=rev_prod
DB_PASSWORD=06071967
DB_NAME=revolution_print

# --- JWT ---
JWT_SECRET=CHANGE_ME_random_64_char_key
JWT_EXPIRATION=7d

# --- Порты (внутренние, менять обычно не нужно) ---
BACKEND_PORT=3000

# --- CORS ---
# Если фронтенд на том же домене, можно оставить пустым
CORS_ORIGIN=https://print.example.com

# --- E-mail уведомления (опционально) ---
# SMTP_HOST=smtp.yandex.ru
# SMTP_PORT=465
# SMTP_USER=noreply@example.com
# SMTP_PASS=

# --- Бэкапы (опционально) ---
# BACKUP_KEEP_DAYS=14
